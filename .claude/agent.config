# .claude/agent.config — single source of truth for the routed agent system (v4)
# Shell-sourceable KEY="VALUE" lines. Read by gate.sh and referenced by
# CLAUDE.md / ROUTING.md so gate commands and budgets exist in EXACTLY ONE place.
#
# Precedence (highest wins):  environment variable  >  this file  >  built-in default
# e.g. `CLAUDE_VERIFY_CMD="python -m pytest -q tests/panel" claude` overrides per-session.

# ---- Verification surface (loop 3 gates; empty = slot skipped) --------------
VERIFY_CMD="python -m pytest -q"   # primary   — harness suite + project tests (M1 adds scraper fixture/gate tests)
LINT_CMD=""                        # secondary — none configured yet (add ruff when a config lands)
UI_VERIFY_CMD="python -m pytest -q tests/panel_dashboard/test_server_smoke.py"   # surface - dashboard HTTP UI smoke (Wave 5)

# ---- Loop budgets (stop conditions — prevent autonomous thrash) --------------
MAX_IMPL_ATTEMPTS="3"    # implementer attempts per task before forced escalation to REVIEWER->PLANNER
MAX_REVIEW_CYCLES="2"    # implement->review cycles before hard stop to the human
MAX_BULK_RETRIES="1"     # grunt retries before promotion to IMPLEMENTER (ROUTING.md Rule 5)

# ---- Model lineup (informational — must mirror .claude/agents/*.md frontmatter)
# Full Fable-access plan: Fable 5 plans/arbitrates + synthesizes the panel; Opus reviews.
PLANNER_MODEL="claude-fable-5"
DRAFTER_MODEL="sonnet"
IMPLEMENTER_MODEL="sonnet"
REVIEWER_MODEL="claude-opus-4-8"
BULK_MODEL="haiku"

# ---- Verdict artifact ---------------------------------------------------------
VERDICT_PATH=".claude/state/verdict.json"   # reviewer writes here; verdict_lint validates
# Panel satellite (v5) writes an additional panel_verdict.json; gate.sh + verdict_lint.py
# gain a panel branch in Wave 1. PANEL_* config keys are added in Wave 4.

# ---- Panel satellite (v5) — PANEL_ENABLED=0 reproduces v4 behavior exactly ----
# Read by panel/config.py (env > this file > built-in default, like the gate above).
# Slugs are full OpenRouter dotted IDs (verified 2026-07-09). Cost truth is usage.cost.
PANEL_ENABLED="1"                  # armed 2026-07-13 (owner-provided OpenRouter key; first use: m6 data strategy)
PANEL_TRIGGER="novelty"            # always|novelty|escalation (lead consumes; not enforced here)
PANEL_PROVIDER="openrouter"
PANEL_ROUTING="exacto"
PANEL_MODE_PLAN="aggregate"        # PLAN gate: aggregator synthesis
PANEL_MODE_REVIEW="union"          # REVIEW gate: union + arbiter-on-disputed
PANEL_MAX_COST_USD="2.00"          # per-invocation cost cap
PANEL_VERDICT_PATH=".claude/state/panel_verdict.json"   # gate.sh GATE 4 lints this if present
PANEL_PLAN_LINEUP="anthropic/claude-fable-5,openai/gpt-5.6-sol-pro"
PANEL_PLAN_SYNTH="openai/gpt-5.6-sol-pro"   # owner request 2026-07-13: sol-pro synthesizes the plan gate
PANEL_REVIEW_LINEUP="anthropic/claude-opus-4.8,openai/gpt-5.6-sol-pro,openai/gpt-5.6-terra-pro"
PANEL_REVIEW_ARBITER="anthropic/claude-fable-5"

# ---- Asset pipeline (Rule 13) — ASSET_ENABLED=0 keeps asset-forge dormant ------
# Read by the asset-forge skill (.claude/skills/asset-forge/); judging runs via
# panel.asset_qa over OpenRouter. Generator ids are Atlas Cloud model ids.
ASSET_ENABLED="0"                  # 0 = asset-forge skill refuses to run · 1 = active
ASSET_MODEL_DEFAULT="google/nano-banana-2-pro"   # generator: photoreal / UI comps
ASSET_MODEL_TEXTED="openai/gpt-image-2"          # generator when the asset bears text
ASSET_QA_JUDGE="auto"              # auto = cross-family pick; slug override still cross-family
ASSET_MAX_ATTEMPTS="3"             # generate->judge attempts per asset
ASSET_MAX_COST_USD="1.00"          # per-asset loop cap (generation + judging)
# Video mode (visual-track QA via frame sampling; audio criteria fail closed).
# Seedance 2.0 has NATIVE AUDIO (approver ruling) — the AUDIO key is an override
# seam only (Veo 3.1 is the documented alternative). Ids are Atlas Cloud ids —
# the skill discovers exact ids via the MCP before generating.
ASSET_VIDEO_MODEL_DEFAULT="bytedance/seedance-2.0-fast"
ASSET_VIDEO_MODEL_AUDIO="bytedance/seedance-2.0-fast"
ASSET_VIDEO_MAX_COST_USD="5.00"    # per-video loop cap (generation + judging)
ASSET_VIDEO_QA_FRAMES="10"         # frames sampled per judge call
